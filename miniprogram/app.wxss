page {
  min-height: 100%;
  background: #FBFAF6;
  color: #202124;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", sans-serif;
  font-size: 30rpx;
  line-height: 1.55;
}

view,
text,
image,
button,
input,
textarea,
scroll-view {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  background: transparent;
  border: 0;
  line-height: inherit;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
  background: #FBFAF6;
}

.section-title {
  margin: 32rpx 0 18rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #202124;
}

.muted {
  color: #70757A;
}

.pill {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #EEF3F6;
  color: #4F8F68;
  font-size: 24rpx;
}
