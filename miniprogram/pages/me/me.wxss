.profile-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 30rpx;
  border-radius: 34rpx;
  background: #FFFFFF;
}

.profile-card__avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #F28C38;
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 96rpx;
  text-align: center;
}

.profile-card__title {
  font-size: 38rpx;
  font-weight: 900;
}

.profile-card__body {
  margin-top: 4rpx;
  color: #70757A;
  font-size: 26rpx;
}

.login-panel {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
}

.login-panel__title {
  color: #202124;
  font-size: 32rpx;
  font-weight: 900;
}

.login-panel__body {
  margin-top: 10rpx;
  color: #70757A;
  font-size: 26rpx;
  line-height: 1.6;
}

.family-name-input {
  box-sizing: border-box;
  width: 100%;
  height: 84rpx;
  margin-top: 22rpx;
  padding: 0 28rpx;
  border-radius: 24rpx;
  background: #F7F4EE;
  color: #202124;
  font-size: 30rpx;
}

.login-panel__button,
.logout-button {
  margin-top: 22rpx;
  height: 84rpx;
  border-radius: 42rpx;
  background: #F28C38;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 84rpx;
}

.login-panel__button--secondary {
  background: #EEF3F6;
  color: #202124;
}

.logout-button {
  background: #EEF3F6;
  color: #202124;
}

.member-list,
.setting-list {
  border-radius: 28rpx;
  background: #FFFFFF;
  overflow: hidden;
}

.member-row,
.setting-row {
  display: flex;
  align-items: center;
  min-height: 92rpx;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #F0EDE8;
}

.member-row:last-child,
.setting-row:last-child {
  border-bottom: 0;
}

.member-row__avatar {
  width: 54rpx;
  height: 54rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  background: #EEF3F6;
  color: #4F8F68;
  font-size: 24rpx;
  line-height: 54rpx;
  text-align: center;
}

.member-row__name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
}

.member-row__role,
.setting-row__arrow {
  color: #70757A;
  font-size: 26rpx;
}

.draft-card {
  padding: 24rpx;
  border-radius: 28rpx;
  background: #EEF3F6;
}

.draft-card__title {
  font-size: 30rpx;
  font-weight: 800;
}

.draft-card__body,
.draft-card--empty {
  color: #70757A;
  font-size: 26rpx;
}

.setting-row {
  justify-content: space-between;
  font-size: 30rpx;
}
