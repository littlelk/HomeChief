.create-page {
  padding-bottom: 150rpx;
}

.cover-upload {
  width: 100%;
  height: 360rpx;
  border-radius: 34rpx;
  background: #EEF3F6;
  overflow: hidden;
}

.cover-upload__image {
  width: 100%;
  height: 100%;
}

.cover-upload__empty {
  color: #4F8F68;
  font-size: 30rpx;
  line-height: 360rpx;
}

.form-error {
  margin-top: 12rpx;
  color: #D93025;
  font-size: 26rpx;
}

.form-section {
  margin-top: 28rpx;
}

.form-label {
  margin-bottom: 12rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.form-input,
.form-textarea {
  width: 100%;
  border-radius: 24rpx;
  background: #FFFFFF;
  font-size: 28rpx;
}

.form-input {
  height: 82rpx;
  padding: 0 24rpx;
}

.form-textarea {
  min-height: 170rpx;
  padding: 22rpx 24rpx;
}

.step-editor {
  margin-bottom: 18rpx;
  padding: 18rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
}

.step-editor__body {
  margin-top: 14rpx;
  background: #FBFAF6;
}

.add-step {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 74rpx;
  border-radius: 999rpx;
  background: #EEF3F6;
  color: #4F8F68;
  font-size: 28rpx;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
}

.bottom-actions__primary,
.bottom-actions__secondary {
  height: 78rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.bottom-actions__primary {
  background: #F28C38;
  color: #FFFFFF;
}

.bottom-actions__secondary {
  background: #EEF3F6;
  color: #202124;
}
