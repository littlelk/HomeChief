.recipes-hero {
  padding: 28rpx;
  border-radius: 32rpx;
  background: #EEF3F6;
}

.recipes-hero__title {
  font-size: 42rpx;
  font-weight: 800;
}

.recipes-hero__body {
  margin-top: 8rpx;
  color: #70757A;
  font-size: 28rpx;
}

.recipe-search {
  width: 100%;
  height: 82rpx;
  margin-top: 28rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #FFFFFF;
  font-size: 28rpx;
}

.filter-row {
  margin: 22rpx 0;
  white-space: nowrap;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  height: 58rpx;
  margin-right: 12rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #EEF3F6;
  color: #4F8F68;
  font-size: 26rpx;
}

.filter-chip--active {
  background: #F28C38;
  color: #FFFFFF;
}

.recipe-list {
  background: #FFFFFF;
  border-radius: 30rpx;
  overflow: hidden;
}

.recipe-row {
  display: flex;
  gap: 20rpx;
  padding: 22rpx;
  border-bottom: 1rpx solid #F0EDE8;
}

.recipe-row:last-child {
  border-bottom: 0;
}

.recipe-row__cover {
  width: 144rpx;
  height: 144rpx;
  flex: 0 0 144rpx;
  border-radius: 24rpx;
  background: #EEF3F6;
}

.recipe-row__content {
  min-width: 0;
  flex: 1;
}

.recipe-row__name {
  font-size: 32rpx;
  font-weight: 800;
}

.recipe-row__meta {
  margin-top: 6rpx;
  color: #70757A;
  font-size: 24rpx;
}

.recipe-row__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 14rpx;
}
