.recipe-cover {
  width: 100%;
  height: 430rpx;
  border-radius: 34rpx;
  background: #EEF3F6;
}

.recipe-title {
  margin-top: 28rpx;
  font-size: 48rpx;
  font-weight: 900;
}

.recipe-meta {
  margin-top: 8rpx;
  color: #70757A;
  font-size: 26rpx;
}

.recipe-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.detail-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 28rpx;
}

.detail-actions__primary,
.detail-actions__secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 78rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.detail-actions__primary {
  background: #F28C38;
  color: #FFFFFF;
}

.detail-actions__secondary {
  background: #EEF3F6;
  color: #202124;
}

.ingredient-list {
  border-radius: 28rpx;
  background: #FFFFFF;
  overflow: hidden;
}

.ingredient-row {
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #F0EDE8;
  font-size: 28rpx;
}

.ingredient-row:last-child {
  border-bottom: 0;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.step-row {
  display: flex;
  gap: 18rpx;
}

.step-row__number {
  width: 52rpx;
  height: 52rpx;
  flex: 0 0 52rpx;
  border-radius: 50%;
  background: #4F8F68;
  color: #FFFFFF;
  font-size: 26rpx;
  line-height: 52rpx;
  text-align: center;
}

.step-row__content {
  flex: 1;
  padding-bottom: 22rpx;
  border-bottom: 1rpx solid #F0EDE8;
}

.step-row__title {
  font-size: 30rpx;
  font-weight: 800;
}

.step-row__body {
  margin-top: 6rpx;
  color: #3C4043;
  font-size: 28rpx;
}

.step-row__image {
  width: 100%;
  height: 260rpx;
  margin-top: 14rpx;
  border-radius: 24rpx;
}

.family-note,
.related-post {
  padding: 24rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
}

.related-post {
  margin-bottom: 18rpx;
}

.related-post__title {
  margin-bottom: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
}
