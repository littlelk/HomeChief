.create-life-page {
  padding-bottom: 132rpx;
}

.form-section {
  margin-top: 28rpx;
}

.form-label {
  margin-bottom: 12rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.life-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
  font-size: 30rpx;
}

.photo-upload {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 24rpx;
}

.photo-upload__image,
.photo-upload__button {
  width: 100%;
  height: 208rpx;
  border-radius: 24rpx;
  background: #EEF3F6;
}

.photo-upload__button {
  color: #F28C38;
  font-size: 48rpx;
  line-height: 208rpx;
}

.form-error {
  margin-top: 12rpx;
  color: #D93025;
  font-size: 26rpx;
}

.tag-row {
  display: flex;
  gap: 10rpx;
  margin-top: 22rpx;
}

.linked-recipe {
  margin-top: 22rpx;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background: #EEF3F6;
  color: #4F8F68;
  font-size: 26rpx;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
}

.bottom-actions__primary {
  height: 78rpx;
  border-radius: 999rpx;
  background: #F28C38;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
}
