.photo-grid {
  display: grid;
  gap: 12rpx;
}

.photo-grid--single {
  grid-template-columns: 1fr;
}

.photo-grid--grid {
  grid-template-columns: repeat(2, 1fr);
}

.photo-grid__image {
  width: 100%;
  height: 260rpx;
  border-radius: 28rpx;
  background: #EEF3F6;
}

.photo-grid--single .photo-grid__image {
  height: 390rpx;
}
